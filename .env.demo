# ShellAtlas — DEMO mode
#
# No external services required. All screens work against seeded in-memory data.
# Rename this file to .env and run:
#   Desktop: ./gradlew :composeApp:run
#   Android: build with the "demo" product flavor
#   iOS:     run without SHELLDOC_FLAVOR set in the scheme (defaults to demo)
#   Web:     ./gradlew :composeApp:wasmJsBrowserDevelopmentRun
#
# Ollama (local AI) is always available on the default port. Override only if needed.
SHELLDOC_APP_ENVIRONMENT=DEV

# Ollama — optional overrides
# SHELLDOC_OLLAMA_BASE_URL=http://127.0.0.1:11434
# SHELLDOC_OLLAMA_MODEL=llama3.2
