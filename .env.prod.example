# ShellAtlas — PROD mode template
#
# Copy this file to .env.prod (or .env), fill in real values, then run:
#   Desktop: ./gradlew :composeApp:run -PshellFlavor=prod
#   Android: build with the "prod" product flavor
#   iOS:     add SHELLDOC_FLAVOR=prod to the Xcode scheme's environment variables
#   Web:     ./gradlew :composeApp:wasmJsBrowserDevelopmentRun -PshellFlavor=prod
#
# NEVER commit a file that contains real secrets.

SHELLDOC_APP_ENVIRONMENT=PROD

# Supabase — required for authentication
SHELLDOC_PROD_SUPABASE_URL=https://your-project.supabase.co
SHELLDOC_PROD_SUPABASE_ANON_KEY=your-anon-key

# Internal API — required for document sync
SHELLDOC_PROD_API_BASE_URL=https://your-api.example.com
SHELLDOC_PROD_API_BEARER_TOKEN=your-bearer-token

# Ollama — AI always runs locally (same in every environment)
SHELLDOC_OLLAMA_BASE_URL=http://127.0.0.1:11434
SHELLDOC_OLLAMA_MODEL=llama3.2
